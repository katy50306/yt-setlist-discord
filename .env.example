# === 必要 ===

# YouTube Data API v3 金鑰（申請教學見 docs/youtube-api-setup.md）
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# Discord Webhook URL（JSON 陣列）（申請教學見 docs/discord-webhook-setup.md）
DISCORD_WEBHOOK_URLS=["https://discord.com/api/webhooks/xxx/yyy"]

# HTTP server 認證密碼（只用英文字母和數字，避免 URL 特殊字元問題）
# 產生隨機密碼：https://www.browserling.com/tools/random-hex
API_TOKEN=your_password_here

# === 可選 ===

# 優先作者 — 填 YouTube 顯示名稱，這些作者的歌單留言會優先採用
# 有設時會進入「冷卻期」邏輯：直播結束後 N 小時內只等優先作者留言
# PREFERRED_AUTHORS=["@KL-gr1my","@username"]

# 優先作者冷卻期（小時，預設 6）— 直播結束後多少小時內只等優先作者
# PREFERRED_AUTHOR_COOLDOWN_HOURS=6

# 附加關鍵字 — 加在預設關鍵字之後（不會覆蓋預設的 セトリ、setlist 等）
# EXTRA_KEYWORDS=["歌ってみた","cover"]

# 最低讚數門檻 — 過濾讚數不足的時間戳留言（預設 10）
# MIN_LIKES=10

# 日期查詢時每頻道最多回傳的影片數（預設 50，最大 50）
# SEARCH_MAX_RESULTS=50

# 播放清單前綴：UULV=直播（預設）、UU=全部上傳、UULF=完整影片、UUSH=Shorts
# PLAYLIST_PREFIX=UULV

# Discord 訊息時間顯示的時區（預設 Asia/Tokyo）
# 參考：https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TIMEZONE=Asia/Tokyo

# Docker 容器時區（預設 UTC）
# 參考：https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=Asia/Taipei

# 定時檢查排程（cron 格式，預設每天 00:00）
# Docker：依 TZ 設定的時區  Workers/Lambda：UTC
# CRON_SCHEDULE=0 0 * * *

# HTTP server 埠號（預設 3000）
# PORT=3000

# 狀態檔案路徑（僅 Docker/Node.js 使用，預設 ./data/state.json）
# STATE_FILE_PATH=./data/state.json
